# Go 'Mothership' Server Env Vars

# Enables the /admin route for the following user
ADMIN_EMAIL=
# LLM_PROVIDER=anthropic
# LLM_PROVIDER=ollama

# Claude
ANTHROPIC_API_KEY=sk-ant-api03-z1fIOe_S7s...CAAA
ANTHROPIC_MODEL=claude-haiku-4-5
# Supported Anthropic Models can be found here:
# https://platform.claude.com/docs/en/about-claude/models/overview

# OPENAI_MODEL=gpt-whatever
# OPENAI_API_KEY=gsk_iO5OaP...CfX9
# OPENAI_BASE_URL=https://openai.whatever.com/v1
OPENAI_TIMEOUT_MS=30000

# groq
CHATCOMPLETION_RESPONSE_FORMAT=json_object
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Ollama fallback (set LLM_PROVIDER=ollama to use)
OLLAMA_BASE_URL=http://10.0.0.100:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_MS=60000

GOOGLE_CLIENT_ID=47...au.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOC...Oq
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/callback
SESSION_SECRET=65...9c

# Contractor view freshness thresholds (days). Price/lead-time snapshots
# captured at SPEC time are shown amber after this many days, red after
# the second threshold. Tunable post-launch after observing real
# contractor use.
SALLY_CONTRACTOR_STALE_AMBER_DAYS=30
SALLY_CONTRACTOR_STALE_RED_DAYS=90