{
  "manifest_version": 3,
  "name": "Sally SPEC PoC",
  "description": "Capture product page specs into an editable Sally schedule proposal.",
  "version": "0.3.12",
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": [
    "contextMenus",
    "cookies",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "https://dev.spexxtool.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "fonts/*.woff2"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "exclude_matches": [
        "http://localhost:8080/*",
        "https://dev.spexxtool.com/*"
      ],
      "js": [
        "contentScript.js"
      ],
      "run_at": "document_idle"
    }
  ]
}