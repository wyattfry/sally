{
  "manifest_version": 3,
  "name": "Sally SPEC PoC",
  "description": "Capture product page specs into an editable Sally schedule proposal.",
  "version": "0.1.0",
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": ["contextMenus", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
