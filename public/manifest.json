{
  "manifest_version": 3,
  "name": "Sally SPEC PoC",
  "description": "Capture product page specs into an editable Sally schedule proposal.",
  "version": "0.1.0",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}

